# Host-specific override for the watchdog systemd unit only.
#
# watchdog runs as a host systemd service (not Docker Compose), so it can't
# resolve the compose-network "redis" hostname used by /opt/alphadivision/.env.
# Redis is published to the host on 127.0.0.1:6379 (see docker-compose.yml).
#
# systemd applies multiple EnvironmentFile= directives in the order they're
# listed, with later ones overriding earlier ones for the same key. This file
# is loaded via a second EnvironmentFile= line placed AFTER
# /opt/alphadivision/.env in watchdog.service, which is what gives it
# precedence to override REDIS_URL.
#
# Not a secret — safe to commit.
REDIS_URL=redis://127.0.0.1:6379
